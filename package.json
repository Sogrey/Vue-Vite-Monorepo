{
  "name": "vue-vite-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:distribute": "node scripts/build-distribute.js",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "clean": "turbo clean && node -e \"const fs=require('fs'); if(fs.existsSync('build')) fs.rmSync('build', {recursive:true})\"",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@vue/tsconfig": "^0.9.0",
    "prettier": "^3.4.2",
    "turbo": "^2.4.4",
    "typescript": "~5.9.3"
  },
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
