{
  "name": "vue-vite-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:distribute": "pnpm docs:all && node scripts/build-distribute.js",
    "docs:sdk1": "npx jsdoc --configure scripts/jsdoc/sdk1.conf.json --pedantic",
    "docs:sdk2": "npx jsdoc --configure scripts/jsdoc/sdk2.conf.json --pedantic",
    "docs:all": "pnpm docs:sdk1 && pnpm docs:sdk2 && pnpm docs:copy",
    "docs:copy": "node scripts/copy-docs.js",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "clean": "turbo clean && node -e \"const fs=require('fs'); if(fs.existsSync('build')) fs.rmSync('build', {recursive:true})\"",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@vue/tsconfig": "^0.9.0",
    "jsdoc": "^4.0.5",
    "jsdoc-babel": "^0.5.0",
    "prettier": "^3.4.2",
    "taffydb": "^2.7.3",
    "turbo": "^2.4.4",
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "pnpm@10.6.5"
}
