<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><?js= (title ? (title + ' - ') : '') + 'JSDoc Documentation' ?></title>

    <!--[if lt IE 9]>
      <script src="javascript/html5.js"></script>
    <![endif]-->
    <link href="styles/jsdoc-default.css" rel="stylesheet">
</head>
<body>

<div id="mainIndex">

<div class='logo-wrapper'>
    <a href="index.html"><img src="images/logo.png" class="logo"></a>
    <span class="version"><?js= env && env.conf && env.conf.version ? 'v' + env.conf.version : 'v1.0.0' ?></span>
</div>

<div class="nav">
    <div class="menu">
        <div class="search-wrapper">
            <input type="text" class="classFilter" id="ClassFilter" placeholder="Search">
            <div class="shortcut"><kbd>Ctrl</kbd><kbd>K</kbd></div>
        </div>
        <?js= this.nav ?>
    </div>
</div>

    <?js
        // 只显示 mainpage 和 package，不显示 files
        var filteredDocs = docs.filter(function(doc) {
            return doc.kind === 'mainpage' || doc.kind === 'package';
        });
        filteredDocs.forEach(function(doc) {
    ?>
        <?js if (doc.kind === 'mainpage') { ?>
            <section class="readme-section">
                <article>
                    <?js if (doc.readme) { ?>
                        <?js= doc.readme ?>
                    <?js } ?>
                </article>
            </section>
        <?js } else if (doc.kind === 'package') { ?>
            <h3><?js= doc.name ?> <?js= doc.version ?></h3>
            <?js if (doc.description) { ?>
                <p><?js= doc.description ?></p>
            <?js } ?>
        <?js } ?>
    <?js }); ?>

    <div class="help">
        Need help? Use AI.
    </div>

    <footer>
        Documentation generated by <a href="https://github.com/jsdoc3/jsdoc">JSDoc <?js= env.version.number ?></a>
    </footer>
</div>

<script>
document.getElementById('ClassFilter').focus();
</script>

<script src="javascript/doc.js"></script>

</body>
</html>
